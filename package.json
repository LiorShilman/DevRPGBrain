{
  "name": "devrpg-brain",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.6.4",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:api": "turbo run dev --filter=@devrpg/api",
    "dev:desktop": "turbo run dev --filter=@devrpg/desktop",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "prisma:migrate": "npm run prisma:migrate --workspace=apps/api",
    "prisma:studio": "npm run prisma:studio --workspace=apps/api",
    "kill:api": "npx kill-port 3001",
    "dist": "turbo run build && npm run dist --workspace=apps/desktop"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.5.4"
  }
}
